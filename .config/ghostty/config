theme = "Ayu Mirage"
cursor-style = block
cursor-style-blink = false

# Send raw interrupt signal for Ctrl+C (avoids "9;5u" being printed)
keybind = ctrl+c=text:\x03
shell-integration-features = no-cursor
font-family = "ZedMono Nerd Font Mono"
font-size = 14


# Splits (matches tmux ctrl+a then s/v)
keybind = ctrl+a>s=new_split:right
keybind = ctrl+a>v=new_split:down

# Toggle zoom current split (matches tmux ctrl+a z)
keybind = ctrl+a>z=toggle_split_zoom

# Move between splits (matches tmux ctrl+a then hjkl)
keybind = ctrl+a>h=goto_split:left
keybind = ctrl+a>j=goto_split:bottom
keybind = ctrl+a>k=goto_split:top
keybind = ctrl+a>l=goto_split:right

# Rename tab (matches tmux ctrl+a ,)
keybind = ctrl+a>,=prompt_tab_title

# Switch tabs by number (matches tmux ctrl+a number)
keybind = ctrl+a>1=goto_tab:1
keybind = ctrl+a>2=goto_tab:2
keybind = ctrl+a>3=goto_tab:3
keybind = ctrl+a>4=goto_tab:4
keybind = ctrl+a>5=goto_tab:5
keybind = ctrl+a>6=goto_tab:6
keybind = ctrl+a>7=goto_tab:7
keybind = ctrl+a>8=goto_tab:8
keybind = ctrl+a>9=goto_tab:9

# Reload config (matches tmux ctrl+a r)
keybind = ctrl+a>r=reload_config


working-directory = /Users/luke/Development
